# KinderVerse LLM 설정
# 이 파일을 복사해 .env 로 만들고 키를 채우세요:  cp .env.example .env
# .env 는 git 에 커밋되지 않습니다(.gitignore 처리됨).

# ── OpenAI(GPT) 사용 시 ──  (둘 중 OpenAI 가 우선 적용됩니다)
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o             # 선택: 텍스트 생성 모델 (기본 gpt-4o)
# OPENAI_BASE_URL=https://api.openai.com/v1   # 선택: 프록시/호환 엔드포인트

# 이미지 생성 (최신 이미지 모델 gpt-image-2, 2026-04 출시)
# OPENAI_IMAGE_MODEL=gpt-image-2  # 선택: 기본 gpt-image-2 (gpt-image-1.5/1 도 가능)
# OPENAI_IMAGE_SIZE=1024x1024     # 선택: 1024x1024 | 1536x1024 | 1024x1536 | auto
# OPENAI_IMAGE_QUALITY=high       # 선택: low | medium | high | auto (기본 high)
# 참고: gpt-image 계열은 OpenAI 조직 인증(verification)이 필요할 수 있습니다.

# ── Anthropic(Claude) 사용 시 ──
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
